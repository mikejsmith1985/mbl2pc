#!/usr/bin/env bash
# Forge Workflow Pre-Commit Hook (Enhanced)
# Generated by Forge Terminal Workflow Architect
# Enforces: main branch block, test file gate, CHANGELOG, naming, branch naming.
# Bypass with: git commit --no-verify (bypasses are logged)

set +e
violations=()
warnings=()

# ── MAIN BRANCH BLOCK (Gate 2) ──────────────────────────────────────────
# Commits directly to main are forbidden. All work must happen on feature branches.
current_branch=$(git branch --show-current 2>/dev/null)
if [[ "$current_branch" == "main" || "$current_branch" == "master" ]]; then
    violations+=("MAIN BRANCH: Cannot commit directly to main — create a feature branch first")
fi

# Branch Naming Check
if [[ -n "$current_branch" ]] && ! echo "$current_branch" | grep -qE "^(main|master|develop|feature/.+|fix/.+|chore/.+|docs/.+|hotfix/.+|release/.+)$"; then
    violations+=("BRANCH: '$current_branch' does not match naming convention")
fi

# Get Staged Files
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
[[ -z "$staged_files" ]] && exit 0

# Filter to source files
source_files=$(echo "$staged_files" | grep -E '\.(go|js|jsx|ts|tsx|py|rs|java|cs)$')

# ── TEST FILE GATE (Gate 4) ─────────────────────────────────────────────
# Every new source file must have a corresponding test file staged or on disk.
# Build output directories are excluded — they contain compiled artifacts, not
# authored source code, and must never be flagged for missing test coverage.
new_source_files=$(git diff --cached --name-only --diff-filter=A 2>/dev/null | grep -E '\.(go|js|jsx|ts|tsx|py|rs|java|cs)$' | grep -vE '^(cmd/forge/web/|frontend/dist/|static/assets/|bin/)')
if [[ -n "$new_source_files" ]]; then
    while IFS= read -r new_file; do
        # Skip files that are themselves test files
        if echo "$new_file" | grep -qE '(_test\.go|\.test\.(js|jsx|ts|tsx)|\.spec\.(js|jsx|ts|tsx)|_test\.py|_test\.rs)$'; then
            continue
        fi
        extension="${new_file##*.}"
        base_name="${new_file%.*}"
        has_test=false
        if [[ "$extension" == "go" ]]; then
            expected_test="${base_name}_test.go"
            if echo "$staged_files" | grep -qF "$expected_test" || [[ -f "$expected_test" ]]; then
                has_test=true
            fi
        else
            # JS/TS: check for .test and .spec variants
            for test_suffix in ".test.${extension}" ".spec.${extension}"; do
                expected_test="${base_name}${test_suffix}"
                if echo "$staged_files" | grep -qF "$expected_test" || [[ -f "$expected_test" ]]; then
                    has_test=true
                    break
                fi
            done
        fi
        if [[ "$has_test" == "false" ]]; then
            violations+=("TEST FILE: New source file '$new_file' has no corresponding test file")
        fi
    done <<< "$new_source_files"
fi

# ── CHANGELOG CHECK (Gate 7 — upgraded to violation) ────────────────────
# Source files changed but CHANGELOG.md not updated = blocking violation.
has_source_changes=false
[[ -n "$source_files" ]] && has_source_changes=true
changelog_updated=$(echo "$staged_files" | grep -c "CHANGELOG\.md$")
if $has_source_changes && [[ "$changelog_updated" -eq 0 ]]; then
    violations+=("CHANGELOG: Source files changed but CHANGELOG.md was not updated")
fi

# Report Results
if [[ ${#violations[@]} -gt 0 ]]; then
    echo -e "\n\033[31mPRE-COMMIT VIOLATIONS (blocking):\033[0m"
    for v in "${violations[@]}"; do echo -e "  \033[31m* $v\033[0m"; done
fi
if [[ ${#warnings[@]} -gt 0 ]]; then
    echo -e "\n\033[33mPRE-COMMIT WARNINGS (non-blocking):\033[0m"
    for w in "${warnings[@]}"; do echo -e "  \033[33m* $w\033[0m"; done
fi
if [[ ${#violations[@]} -eq 0 ]] && [[ ${#warnings[@]} -eq 0 ]]; then
    echo -e "\033[32mPre-commit checks passed\033[0m"
fi

if [[ ${#violations[@]} -gt 0 ]]; then
    echo -e "\033[31mCommit blocked. Fix violations or use --no-verify to bypass.\033[0m"
    exit 1
fi
exit 0
